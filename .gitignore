# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Even Hub package output
*.ehpk

# Cached portal session for scripts/deploy-portal.mjs — keeps cookies so we
# don't have to log in on every upload. NEVER commit this file.
.even-portal-session.json

# Page HTML dump from a failed deploy-portal.mjs run — for selector debugging
.deploy-portal-failure.html

# Output of scripts/inspect-portal.mjs — page snapshot for selector tuning
inspect-portal.out
inspect-portal.summary.txt

# Output of scripts/inspect-hub.mjs — Playwright-based dev portal inspector
inspect-hub.out
inspect-hub.summary.txt
.hub-portal-session.json
# Output files from scripts/inspect-hub-project.mjs (NOT the script itself)
inspect-hub-project.summary.txt
inspect-hub-project.list.html
inspect-hub-project.detail.html
inspect-hub-project.upload.html
.upload-dev-failure.html
.upload-dev-after-file.html
.upload-dev-final.html

# Regression test screenshots — regenerated each run
tests/screenshots-regression/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
worker-template/.dev.vars

# Local isolated development worktrees
.worktrees/
